{
  "creates_users_collection": [
    {
      "$group": {
        "_id": "$user.id",
        "screen_name": { "$first": "$user.screen_name" },
        "name": { "$first": "$user.name" },
        "followers_count": { "$first": "$user.followers_count" },
        "friends_count": { "$first": "$user.friends_count" }
      }
    },
    { "$out": "users" }
  ],

  "creates_tweets_only_collection": [
    {
      "$project": {
        "_id": 1,
        "id": 1,
        "created_at": 1,
        "text": 1,
        "retweet_count": 1,
        "favorite_count": 1,
        "user_id": "$user.id"
      }
    },
    { "$out": "tweets_only" }
  ]
}